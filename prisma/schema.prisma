// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          String    @default("user") // user, admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  articles      Article[]
  sessions      Session[]
  trackedMaterials TrackedMaterial[]
  portfolioAssets  PortfolioAsset[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  content     String   @db.LongText
  aiSummary   String?  @db.LongText
  aiAnalysis  String?  @db.LongText
  imageUrl    String?
  sourceUrl   String?  @db.Text
  sourceName  String?
  category    String
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([slug])
  @@index([category])
}

model Video {
  id          String   @id @default(cuid())
  title       String
  url         String
  thumbnail   String?
  source      String   @default("manual") // manual, youtube_channel
  videoType   String   @default("video") // video, short
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model RareEarthMaterial {
  id          String            @id @default(cuid())
  name        String            @unique
  symbol      String            @unique
  category    String
  price       Float?
  unit        String?
  description String?           @db.Text
  imageUrl    String?
  supply      String?           @db.Text
  demand      String?           @db.Text
  countries   String?           @db.Text // JSON string of countries
  applications String?          @db.Text // JSON string of applications
  lastUpdated DateTime          @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  trackedBy   TrackedMaterial[]

  @@index([name])
  @@index([category])
}

model Newsletter {
  id                  String   @id @default(cuid())
  email               String   @unique
  active              Boolean  @default(true)
  materialPreferences String?  @db.Text // JSON string of selected categories/topics
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([email])
}

model NewsletterReport {
  id          String   @id @default(cuid())
  subject     String
  reportType  String   @default("weekly") // daily, weekly
  htmlContent String   @db.LongText
  sentTo      String   @db.LongText // JSON array of emails
  sentCount   Int      @default(0)
  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([sentAt])
  @@index([reportType])
}

model TrackedMaterial {
  id         String           @id @default(cuid())
  userId     String
  materialId String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  material   RareEarthMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@unique([userId, materialId])
  @@index([userId])
  @@index([materialId])
}

model CommodityPrice {
  id                  String   @id @default(cuid())
  label               String
  symbol              String   @unique
  price               Float
  change              Float?
  previousClose       Float?
  type                String
  marketStatus        String   @default("OPEN")
  lastTradingTimestamp DateTime?
  updatedAt           DateTime @updatedAt
}

model MarketPriceHistory {
  id         String   @id @default(cuid())
  label      String
  symbol     String
  source     String
  interval   String
  open       Float
  high       Float
  low        Float
  close      Float
  volume     Float?
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@unique([symbol, interval, recordedAt])
  @@index([symbol, interval, recordedAt])
  @@index([recordedAt])
}

model MediaAsset {
  id        String   @id @default(cuid())
  kind      String
  filename  String
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
}

model SocialPost {
  id          String   @id @default(cuid())
  text        String   @db.Text
  imageUrl    String?  @db.Text
  imagePrompt String?  @db.Text
  status      String   @default("pending") // pending, approved, published, rejected
  platforms   String?  @db.Text // JSON array: ["linkedin","x","instagram"]
  publishedAt DateTime?
  scheduledAt DateTime?
  emailSent   Boolean  @default(false)
  retryCount  Int      @default(0)
  publishLog  String?  @db.Text // JSON log of publish results per platform
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

model VesselTrack {
  id         String   @id @default(cuid())
  mmsi       String
  shipName   String?
  latitude   Float
  longitude  Float
  heading    Float?
  speed      Float?
  source     String?
  recordedAt DateTime @default(now())

  @@index([mmsi, recordedAt])
  @@index([recordedAt])
}

model FlightTrack {
  id         String   @id @default(cuid())
  icao24      String
  callsign    String?
  latitude    Float
  longitude   Float
  altitude    Float?
  heading     Float?
  velocity    Float?
  source      String?
  recordedAt  DateTime @default(now())

  @@index([icao24, recordedAt])
  @@index([recordedAt])
}

model PortfolioAsset {
  id         String   @id @default(cuid())
  userId     String
  symbol     String
  label      String
  quantity   Float
  buyPrice   Float
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
}
