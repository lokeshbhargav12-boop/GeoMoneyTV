# ============================================
# GeoMoney TV - Environment Variables Template
# Copy this file to .env and fill in your actual values
# ============================================

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# DATABASE (Hostinger MySQL)
# Format: mysql://username:password@host:port/database
# ============================================
DATABASE_URL=mysql://u220613152_root_admin:YOUR_PASSWORD@srv2208.hstgr.io:3306/u220613152_geomoneytv_pro

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your_secure_random_secret_here

# ============================================
# SITE URLs
# ============================================
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# ============================================
# AI / OPENROUTER (Required for newsletters and AI features)
# Get your API key from: https://openrouter.ai/keys
# ============================================
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
OPENROUTER_AI_MODEL=google/gemma-3-27b-it:free

# ============================================
# HUGGING FACE (Optional - for image generation)
# Get your token from: https://huggingface.co/settings/tokens
# ============================================
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here
HF_TOKEN=hf_your_huggingface_token_here

# ============================================
# YOUTUBE API (Required for video sync)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# ============================================
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here

# ============================================
# WEATHER API (Required for weather widget)
# Get your API key from: https://openweathermap.org/api
# ============================================
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key_here

# ============================================
# RARE EARTH / MINERALS API (Optional)
# ============================================
RARE_EARTH_API_URL=https://api.usgs.gov/mrds

# ============================================
# EIA ENERGY API (Required for energy infrastructure live data)
# Get your API key from: https://www.eia.gov/opendata/register.php
# ============================================
EIA_API_KEY=your_eia_api_key_here

# ============================================
# CRON SECURITY (Required for scheduled tasks)
# Generate a secure random string
# ============================================
CRON_SECRET=your_secure_random_cron_secret_key_here

# ============================================
# N8N WEBHOOK (Optional - for social post automation)
# ============================================
N8N_WEBHOOK_SECRET=
N8N_SOCIAL_PUBLISH_WEBHOOK=

# ============================================
# SOCIAL MEDIA APIs (Optional - for auto-publishing)
# ============================================
# X (Twitter) API - Get from https://developer.twitter.com/en/portal/dashboard
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# LinkedIn API - Get from https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=

# Social Image Generation API (Optional)
SOCIAL_IMAGE_API_URL=
SOCIAL_IMAGE_API_KEY=

# ============================================
# ADMIN EMAIL
# ============================================
ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# AIS / VESSEL TRACKING (World Monitor)
# Get your API key from: https://aisstream.io/
# ============================================
AISTREAM_API_KEY=your_aisstream_api_key_here
AISTREAM_STREAM_URL=wss://stream.aisstream.io/v0/stream
AISTREAM_SAMPLE_MS=7000
AISTREAM_MAX_VESSELS=3500

# Legacy AIS Provider (Optional)
AIS_API_URL=
AIS_API_KEY=
AIS_API_AUTH_HEADER=Authorization
AIS_API_SOURCE=Configured AIS provider

# Vessel Finder (Optional)
VESSELFINDER_API_KEY=
VESSELFINDER_LIVEDATA_URL=https://api.vesselfinder.com/livedata
VESSELFINDER_INTERVAL_MINUTES=10

# Vessel Track Settings
VESSEL_TRACK_LOOKBACK_MS=43200000
VESSEL_TRACK_HISTORY_LIMIT=14
VESSEL_TRACK_MIN_PERSIST_INTERVAL_MS=120000

# ============================================
# AIRCRAFT TRACKING (World Monitor)
# ============================================
FLIGHT_TRACK_LOOKBACK_MS=21600000
FLIGHT_TRACK_HISTORY_LIMIT=12
FLIGHT_TRACK_MIN_PERSIST_INTERVAL_MS=120000

# ============================================
# WEBSOCKET SETTINGS
# ============================================
WS_NO_BUFFER_UTIL=1
WS_NO_UTF_8_VALIDATE=1
